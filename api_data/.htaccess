# Bloqueio de seguranca - Plena Factory
# Impede acesso direto aos dados JSON pelo navegador.
# As APIs PHP continuam lendo os arquivos pelo sistema de arquivos local.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

Options -Indexes
