# ============================================
# EXEMPLO DE CONFIGURAÇÃO
# ============================================
# Copie este arquivo para .env e preencha os valores.

# --- Admin Panel ---
ADMIN_SECRET=SUA_SENHA_AQUI

# --- Mercado Pago ---
MP_ACCESS_TOKEN=SEU_TOKEN_AQUI
MP_NOTIFICATION_URL=https://seudominio.com/api_vendas.php?action=webhook

# --- SMTP (Email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Domínio ---
BASE_URL=https://seudominio.com/
PUBLIC_BASE_URL=https://sistemasdegestao.tech
ALLOWED_ORIGIN=https://seudominio.com

# --- Supabase ---
SUPABASE_URL=https://sua-url.supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key-secreta
