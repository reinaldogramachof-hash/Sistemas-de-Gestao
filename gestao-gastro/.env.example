# Optional override for a non-standard license API host. Leave empty in local Vite
# development and production deployments; both use the same-origin API path.
# VITE_LICENSE_API_URL=
# As configurações de licença e ativação são feitas localmente sem dependência de serviços externos ou variáveis de ambiente de IA.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
