# Variáveis necessárias para o funcionamento do Frontend
VITE_SUPABASE_URL=
# Chave pública anon (não use service_role aqui)
VITE_SUPABASE_ANON_KEY=
VITE_GASTRO_TENANT_ID=

# NOTA IMPORTANTE DE SEGURANÇA:
# A variável SUPABASE_SERVICE_KEY (service_role) nunca deve ser colocada neste arquivo
# nem em .env.local do frontend. Ela deve ficar apenas no .env raiz do backend php.

# Opcional: URL da API de licença, deixe vazio para usar a mesma origem
# VITE_LICENSE_API_URL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
